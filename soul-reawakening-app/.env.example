# Soul Reawakening Environment Variables
# Copy this file to .env and fill in your values

# Site URL (update with your Netlify URL after deployment)
VITE_SITE_URL=https://soulreawakening.com

# Calendly
VITE_CALENDLY_URL=https://calendly.com/soulreawakening

# YouTube Playlist Embed
VITE_YOUTUBE_PLAYLIST=https://www.youtube.com/embed/videoseries?list=PLnuFcIyG2-BY2Hir1qtpzBLr0q-f7-_ja

# YouTube Data API v3 (used by Netlify function to fetch playlist videos)
# Get a key at: https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your Google Cloud project
# Set this in Netlify dashboard: Site settings > Environment variables
YOUTUBE_API_KEY=your-youtube-api-key-here

# Analytics (optional)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
